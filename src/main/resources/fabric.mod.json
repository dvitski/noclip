{
  "schemaVersion": 1,

  "id": "noclip",
  "version": "${version}",
  "license": [
    "MIT (Code)",
    "All Rights Reserved (Assets)"
  ],

  "name": "noclip",
  "icon": "assets/noclip/icon.png",
  "description": "Adds a way to noclip in any game mode, like spectator mode",

  "authors": [ "Andante" ],
  "contact": {
    "homepage": "https://modrinth.com/mod/noclip",
    "sources": "https://github.com/andantet/noclip-fabric",
    "issues": "https://github.com/andantet/noclip-fabric/issues"
  },

  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.andante.noclip.impl.NoClipImpl"
    ],
    "client": [
      "dev.andante.noclip.impl.client.NoClipClientImpl"
    ],
    "modmenu": [
      "dev.andante.noclip.impl.client.integration.NoClipModMenuImpl"
    ]
  },

  "mixins": [
    "noclip.mixins.json",
    {
      "config": "noclip.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "noclip.accesswidener",

  "depends": {
    "minecraft": ">=1.21.8",
    "fabric-api": ">=0.133.0",
    "cloth-config": ">=15.0"
  },
  "breaks": {
    "optifabric": "*"
  }
}
